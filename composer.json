{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "ext-pdo_mysql": "*",
        "lab404/laravel-impersonate": "^1.7",
        "laravel/framework": "^12.0",
        "laravel/scout": "^10.24",
        "laravel/tinker": "^2.10.1",
        "nwidart/laravel-modules": "^12.0",
        "openspout/openspout": "^5.3",
        "spatie/laravel-activitylog": "^4.11",
        "spatie/laravel-html": "^3.12",
        "spatie/laravel-permission": "^6.24",
        "yajra/laravel-datatables-oracle": "^12.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "fruitcake/laravel-debugbar": "^4.0",
        "larastan/larastan": "^3.0",
        "laravel/boost": "^2.1",
        "laravel/breeze": "^2.3",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.3",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Modules\\Reference\\": "Modules/Reference/app/",
            "Modules\\Reference\\Database\\Factories\\": "Modules/Reference/database/factories/",
            "Modules\\Reference\\Database\\Seeders\\": "Modules/Reference/database/seeders/",
            "Modules\\PortalAdministration\\": "Modules/PortalAdministration/app/",
            "Modules\\PortalAdministration\\Database\\Factories\\": "Modules/PortalAdministration/database/factories/",
            "Modules\\PortalAdministration\\Database\\Seeders\\": "Modules/PortalAdministration/database/seeders/",
            "Modules\\Portal\\": "Modules/Portal/app/",
            "Modules\\Portal\\Database\\Factories\\": "Modules/Portal/database/factories/",
            "Modules\\Portal\\Database\\Seeders\\": "Modules/Portal/database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --queue=default,exports,imports --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "deploy:clear-routes": [
            "@php artisan route:clear --ansi"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan boost:update --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
