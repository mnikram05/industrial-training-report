{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "allowJs": true,
        "checkJs": false,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "resources/js/**/*.js",
        "resources/js/**/*.jsx",
        "resources/js/**/*.ts",
        "resources/js/**/*.tsx",
        "vite.config.js",
        "tailwind.config.js",
        "postcss.config.js"
    ],
    "exclude": [
        "node_modules",
        "vendor",
        "public",
        "storage",
        "bootstrap/cache"
    ]
}